    <!-- ================================================================
         JAVASCRIPT — All interaction logic.
         Each block is clearly labeled. Edit values marked with !! EDIT !!
         ================================================================ -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {

            // ================================================================
            // LENIS — Smooth scroll initialization
            // Remove this block if you don't want smooth scrolling.
            // ================================================================
            let lenis = null;
            if (typeof Lenis !== 'undefined') {
                lenis = new Lenis({
                    duration: 1.2,
                    // !! EDIT: Change duration (seconds) for faster/slower scroll
                    easing: t => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
                    smooth: true,
                    smoothTouch: false, // Disable on touch for native feel
                });

                // Lenis requires being called every frame
                (function lenisRaf(time) {
                    lenis.raf(time);
                    requestAnimationFrame(lenisRaf);
                })(performance.now());
            }

            // Helper: smooth scroll to an element with Lenis or fallback
            function scrollTo(el, offset = -80) {
                if (lenis) lenis.scrollTo(el, { offset, duration: 1.2 });
                else el.scrollIntoView({ behavior: 'smooth' });
            }
            // ================================================================
            // FLOATING RESUME DOCKING SCROLL EFFECT
            // On mobile (≤768px) the button stays in the hero section and
            // never docks to the fixed header — avoiding top-bar overflow.
            // ================================================================
            const resumeBtn = document.getElementById('resumeBtn');
            const resumePlaceholder = document.getElementById('resume-placeholder');
            let resumeDocked = false;
            let resumeAnimTimeout = null;

            // Returns true when the viewport is in a mobile-width range where
            // docking the resume button would create a cramped header.
            function isMobileViewport() {
                return window.innerWidth <= 768;
            }

            // Cleanly resets the resume button back into its hero placeholder
            // without any transition — used when switching from desktop to mobile.
            function resetResumeToHero() {
                if (resumeAnimTimeout) clearTimeout(resumeAnimTimeout);
                if (!resumeBtn || !resumePlaceholder) return;
                resumeBtn.classList.remove('docked', 'animating');
                resumeBtn.style.cssText = ''; // clear all inline styles
                if (!resumePlaceholder.contains(resumeBtn)) {
                    resumePlaceholder.appendChild(resumeBtn);
                }
                resumeDocked = false;
            }

            function updateResumeDockPosition() {
                if (!resumeBtn || !resumePlaceholder) return;

                // On mobile: always keep the button in the hero section.
                if (isMobileViewport()) {
                    if (resumeDocked) resetResumeToHero();
                    return;
                }

                const sy = window.scrollY;
                const aboutSec = document.getElementById('about');
                const aboutTop = aboutSec ? aboutSec.offsetTop : 300;
                const shouldDock = sy > Math.min(window.innerHeight * 0.4, aboutTop - 160);

                if (shouldDock === resumeDocked) {
                    // If already docked, update its left coordinate on resize to keep it on top-right
                    if (resumeDocked) {
                        resumeBtn.style.left = `${window.innerWidth - 100 - 26}px`;
                    }
                    return;
                }

                resumeDocked = shouldDock;

                if (resumeAnimTimeout) clearTimeout(resumeAnimTimeout);

                if (resumeDocked) {
                    // Docking: transition from placeholder to top-right header
                    const rect = resumeBtn.getBoundingClientRect();

                    // Set initial fixed position at current placeholder position
                    resumeBtn.style.position = 'fixed';
                    resumeBtn.style.top = `${rect.top}px`;
                    resumeBtn.style.left = `${rect.left}px`;
                    resumeBtn.style.width = `${rect.width}px`;
                    resumeBtn.style.height = `${rect.height}px`;

                    // Move button to body to escape parent overflow/transforms
                    document.body.appendChild(resumeBtn);

                    // Force reflow
                    resumeBtn.offsetHeight;

                    // Start animation to docked state
                    resumeBtn.classList.add('animating');
                    resumeBtn.classList.add('docked');

                    resumeBtn.style.top = '22px';
                    resumeBtn.style.left = `${window.innerWidth - 100 - 26}px`;
                    resumeBtn.style.width = '100px';
                    resumeBtn.style.height = '42px';

                    resumeAnimTimeout = setTimeout(() => {
                        resumeBtn.classList.remove('animating');
                    }, 500);
                } else {
                    // Undocking: transition from top-right header back to placeholder using page-relative coordinates to prevent scroll-jump
                    const placeholderRect = resumePlaceholder.getBoundingClientRect();
                    const scrollY = window.scrollY;
                    const scrollX = window.scrollX;

                    // Move button to body and position it absolutely relative to the page starting from docked coordinates
                    resumeBtn.style.position = 'absolute';
                    resumeBtn.style.top = `${22 + scrollY}px`;
                    resumeBtn.style.left = `${(window.innerWidth - 100 - 26) + scrollX}px`;
                    resumeBtn.style.width = '100px';
                    resumeBtn.style.height = '42px';
                    document.body.appendChild(resumeBtn);

                    // Force reflow
                    resumeBtn.offsetHeight;

                    resumeBtn.classList.add('animating');
                    resumeBtn.classList.remove('docked');

                    // Animate to placeholder's page-relative coordinates
                    resumeBtn.style.top = `${placeholderRect.top + scrollY}px`;
                    resumeBtn.style.left = `${placeholderRect.left + scrollX}px`;
                    resumeBtn.style.width = `${placeholderRect.width}px`;
                    resumeBtn.style.height = `${placeholderRect.height}px`;

                    resumeAnimTimeout = setTimeout(() => {
                        // Put back inside placeholder
                        resumePlaceholder.appendChild(resumeBtn);
                        resumeBtn.classList.remove('animating');

                        // Clear styles to let CSS layout handle it natively
                        resumeBtn.style.position = '';
                        resumeBtn.style.top = '';
                        resumeBtn.style.left = '';
                        resumeBtn.style.width = '';
                        resumeBtn.style.height = '';
                    }, 500);
                }
            }

            // Bind scroll and resize events
            window.addEventListener('scroll', updateResumeDockPosition);
            window.addEventListener('resize', () => {
                if (isMobileViewport()) {
                    // Switched to mobile — immediately pull resume button back to hero
                    if (resumeDocked) resetResumeToHero();
                } else if (resumeDocked) {
                    // Desktop resize: keep docked position accurate
                    resumeBtn.style.left = `${window.innerWidth - 100 - 26}px`;
                }
            });

            // Run immediately after layout settles
            setTimeout(() => {
                if (isMobileViewport()) {
                    // Mobile: ensure button is always in hero on load
                    resetResumeToHero();
                    return;
                }
                const sy = window.scrollY;
                const aboutSec = document.getElementById('about');
                const aboutTop = aboutSec ? aboutSec.offsetTop : 300;
                const threshold = Math.min(window.innerHeight * 0.4, aboutTop - 160);
                if (sy > threshold) {
                    resumeDocked = true;
                    document.body.appendChild(resumeBtn);
                    resumeBtn.classList.add('docked');
                    resumeBtn.style.position = 'fixed';
                    resumeBtn.style.top = '22px';
                    resumeBtn.style.left = `${window.innerWidth - 100 - 26}px`;
                    resumeBtn.style.width = '100px';
                    resumeBtn.style.height = '42px';
                } else {
                    resumeDocked = false;
                    resumePlaceholder.appendChild(resumeBtn);
                    resumeBtn.style.position = '';
                    resumeBtn.style.top = '';
                    resumeBtn.style.left = '';
                    resumeBtn.style.width = '';
                    resumeBtn.style.height = '';
                }
            }, 150);

            // ================================================================
            // CUSTOM CURSOR — Dot snaps; ring follows with smooth lag
            // ================================================================
            const cursorDot = document.getElementById('cursor-dot');
            const cursorRing = document.getElementById('cursor-ring');

            // Current mouse position (dot snaps here)
            let mx = window.innerWidth / 2;
            let my = window.innerHeight / 2;

            // Ring's current interpolated position
            let rx = mx, ry = my;

            // Update mouse position on every mouse move
            document.addEventListener('mousemove', e => {
                mx = e.clientX;
                my = e.clientY;
                // Dot follows instantly
                cursorDot.style.left = mx + 'px';
                cursorDot.style.top = my + 'px';
            });

            // Animate ring with LERP each frame
            (function ringLoop() {
                // !! EDIT: Change 0.12 for faster (higher) or slower (lower) ring lag
                rx += (mx - rx) * 0.12;
                ry += (my - ry) * 0.12;
                cursorRing.style.left = rx + 'px';
                cursorRing.style.top = ry + 'px';
                requestAnimationFrame(ringLoop);
            })();

            // Expand ring when hovering interactive elements
            const hoverEls = document.querySelectorAll(
                'a, button, .tilt-card, .tag, .nav-link, [role="button"], .connect-btn'
            );
            hoverEls.forEach(el => {
                el.addEventListener('mouseenter', () => document.body.classList.add('cursor-hover'));
                el.addEventListener('mouseleave', () => document.body.classList.remove('cursor-hover'));
            });

            // Fade cursor out when leaving/entering page
            document.addEventListener('mouseleave', () => {
                cursorDot.style.opacity = '0';
                cursorRing.style.opacity = '0';
            });
            document.addEventListener('mouseenter', () => {
                cursorDot.style.opacity = '1';
                cursorRing.style.opacity = '1';
            });


            // ================================================================
            // NAVIGATION — Show pill after scroll; track active section
            // ================================================================
            const navPill = document.getElementById('navPill');
            const navIndicator = document.getElementById('navIndicator');
            const navLinks = document.querySelectorAll('.nav-link');
            const scrollNudge = document.getElementById('scrollNudge');
            const scrollNudgeMobile = document.getElementById('scrollNudgeMobile');
            const sections = Array.from(document.querySelectorAll('.section[id]'));

            // Shared helper: trigger appear on both desktop pill + mobile circle
            function nudgeAppear() {
                if (scrollNudge)       scrollNudge.classList.add('appeared');
                if (scrollNudgeMobile) scrollNudgeMobile.classList.add('appeared');
            }

            // Shared helper: hide/show both nudge elements together
            function nudgeSetHidden(isHidden) {
                if (scrollNudge && scrollNudge.classList.contains('appeared')) {
                    scrollNudge.classList.toggle('hidden', isHidden);
                }
                if (scrollNudgeMobile && scrollNudgeMobile.classList.contains('appeared')) {
                    scrollNudgeMobile.classList.toggle('hidden', isHidden);
                }
            }

            // ---- Sliding indicator LERP physics ----
            let indL = 0, indW = 0;          // Current position (animated)
            let indTL = 0, indTW = 0;        // Target position
            let indReady = false;

            // Move indicator target to a specific link element
            function setIndicatorTarget(link) {
                indTL = link.offsetLeft;
                indTW = link.offsetWidth;
            }

            // Animate indicator toward target each frame
            (function indicatorLoop() {
                if (!indReady && indTW > 0) {
                    // Snap on first run
                    indL = indTL; indW = indTW; indReady = true;
                } else if (indReady) {
                    // !! EDIT: 0.16 = responsiveness of indicator slide
                    indL += (indTL - indL) * 0.16;
                    indW += (indTW - indW) * 0.16;
                }
                navIndicator.style.cssText = `left:${indL}px; width:${indW}px; height:32px; top:4px;`;
                requestAnimationFrame(indicatorLoop);
            })();

            // Hover: temporarily move indicator to hovered link
            navLinks.forEach(link => {
                link.addEventListener('mouseenter', () => setIndicatorTarget(link));
            });

            // Mouse leaves pill: restore to active section
            navPill.addEventListener('mouseleave', () => {
                const active = navPill.querySelector('.nav-link.active');
                if (active) setIndicatorTarget(active);
            });

            // Scroll event: show/hide pill, track active section
            window.addEventListener('scroll', () => {
                const sy = window.scrollY;

                // Show nav pill after scrolling 80px
                navPill.classList.toggle('visible', sy > 80);

                // Hide both scroll nudge elements (desktop pill + mobile circle) once user scrolls past hero.
                nudgeSetHidden(sy > 60);

                // Active section: pick the last section whose top is within the
                // top 40% of the viewport. For the last section we also check
                // if the user is within 80px of the page bottom so connect
                // always activates when reached.
                const viewH = window.innerHeight;
                const pageH = document.documentElement.scrollHeight;
                const atBottom = sy + viewH >= pageH - 80;

                let current = '';
                sections.forEach(sec => {
                    const top = sec.getBoundingClientRect().top;
                    if (top <= viewH * 0.45) current = sec.id;
                });

                // Force the last section active when at the page bottom
                if (atBottom && sections.length) {
                    current = sections[sections.length - 1].id;
                }

                // Apply .active class and update indicator
                navLinks.forEach(link => {
                    const isActive = link.dataset.section === current;
                    link.classList.toggle('active', isActive);
                    if (isActive) setIndicatorTarget(link);
                });
            });

            // Smooth scroll when clicking nav links
            navLinks.forEach(link => {
                link.addEventListener('click', e => {
                    e.preventDefault();
                    const target = document.querySelector(link.getAttribute('href'));
                    if (!target) return;

                    // For the last section (connect) use offset 0 so Lenis
                    // doesn't try to scroll past the document bottom.
                    const isLast = target === sections[sections.length - 1];
                    scrollTo(target, isLast ? 0 : -80);
                });
            });

            // Scroll nudge — appear on load + click handlers (desktop + mobile)
            if (scrollNudge || scrollNudgeMobile) {
                // Trigger entry transition after the page settles (1.2s)
                setTimeout(() => { nudgeAppear(); }, 1200);

                // Desktop nudge click
                scrollNudge?.addEventListener('click', e => {
                    e.preventDefault();
                    const about = document.getElementById('about');
                    if (about) scrollTo(about, -80);
                });

                // Mobile nudge click
                scrollNudgeMobile?.addEventListener('click', e => {
                    e.preventDefault();
                    const about = document.getElementById('about');
                    if (about) scrollTo(about, -80);
                });
            }

            // Trigger scroll once on load to set initial state
            window.dispatchEvent(new Event('scroll'));


            // ================================================================
            // BRAND LOGO — Back to top + scroll progress ring
            // ================================================================
            const brand = document.getElementById('brand');
            const ringFill = document.getElementById('brandRingFill');

            // Circumference = 2 * PI * r = 2 * 3.14159 * 23 ≈ 144.51
            const CIRC = 2 * Math.PI * 23;

            // Update ring fill offset based on scroll position
            (function progressLoop() {
                const scrolled = window.scrollY;
                const total = document.documentElement.scrollHeight - window.innerHeight;
                const pct = total > 0 ? scrolled / total : 0;
                if (ringFill) ringFill.style.strokeDashoffset = CIRC * (1 - pct);
                requestAnimationFrame(progressLoop);
            })();

            // Click K to scroll back to top
            if (brand) {
                brand.addEventListener('click', () => {
                    if (lenis) lenis.scrollTo(0, { duration: 1.2 });
                    else window.scrollTo({ top: 0, behavior: 'smooth' });
                });
                brand.addEventListener('keydown', e => {
                    if (e.key === 'Enter' || e.key === ' ') brand.click();
                });
            }


            // ================================================================
            // 3D CARD TILT — Subtle perspective tilt on hover
            // !! EDIT: Change MAX_TILT value (degrees) for more or less effect !!
            // ================================================================
            const MAX_TILT = 7; // degrees — keep below 12 for subtlety

            document.querySelectorAll('.tilt-card').forEach(card => {
                card.addEventListener('mousemove', e => {
                    const r = card.getBoundingClientRect();
                    const dx = (e.clientX - r.left - r.width / 2) / (r.width / 2); // -1 to 1
                    const dy = (e.clientY - r.top - r.height / 2) / (r.height / 2); // -1 to 1

                    card.style.transform = `perspective(800px) rotateX(${-dy * MAX_TILT}deg) rotateY(${dx * MAX_TILT}deg) translateZ(4px)`;
                    card.style.transition = 'transform 0.08s ease-out';
                });

                card.addEventListener('mouseleave', () => {
                    card.style.transform = '';
                    card.style.transition = 'transform 0.65s cubic-bezier(0.16, 1, 0.3, 1)';
                });
            });


            // ================================================================
            // PROFILE PHOTO TILT — Slightly stronger tilt on the hero photo
            // ================================================================
            const photoFrame = document.getElementById('photoFrame');
            if (photoFrame) {
                const wrapper = photoFrame.closest('.hero-right');
                wrapper?.addEventListener('mousemove', e => {
                    const r = photoFrame.getBoundingClientRect();
                    const dx = (e.clientX - r.left - r.width / 2) / (r.width / 2);
                    const dy = (e.clientY - r.top - r.height / 2) / (r.height / 2);
                    photoFrame.style.transform = `perspective(700px) rotateX(${-dy * 11}deg) rotateY(${dx * 11}deg)`;
                    photoFrame.style.transition = 'transform 0.08s ease-out';
                });
                wrapper?.addEventListener('mouseleave', () => {
                    photoFrame.style.transform = '';
                    photoFrame.style.transition = 'transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
                });
            }


            // ================================================================
            // MAGNETIC HOVER — Connect buttons subtly follow the cursor
            // !! EDIT: Change STRENGTH for more/less magnetic pull (0–1) !!
            // ================================================================
            const STRENGTH = 0.32;

            document.querySelectorAll('.connect-btn').forEach(btn => {
                btn.addEventListener('mousemove', e => {
                    const r = btn.getBoundingClientRect();
                    const dx = (e.clientX - r.left - r.width / 2) * STRENGTH;
                    const dy = (e.clientY - r.top - r.height / 2) * STRENGTH;
                    btn.style.transform = `translate(${dx}px, ${dy}px) translateY(-3px)`;
                    btn.style.transition = 'transform 0.1s ease-out';
                });
                btn.addEventListener('mouseleave', () => {
                    btn.style.transform = '';
                    btn.style.transition = 'transform 0.55s cubic-bezier(0.16, 1, 0.3, 1)';
                });
            });


            // ================================================================
            // SCROLL REVEAL — Fade+blur elements in as they enter the viewport
            // Any element with class="reveal" or "reveal-stagger" is watched.
            // ================================================================
            const revealObs = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('visible');
                    } else {
                        entry.target.classList.remove('visible');
                    }
                });
            }, {
                threshold: 0.07,
                rootMargin: '0px 0px -30px 0px'
            });

            document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => {
                revealObs.observe(el);
            });

            // Hero section reveals instantly (no scroll needed)
            document.getElementById('hero')?.classList.add('visible');


            // ================================================================
            // HIGHLIGHTS — Horizontal 3D Cylinder Carousel
            // Driven by a continuous rAF render loop (bank-card style).
            // Mouse parallax tilt + touch swipe + dot navigation + auto-advance.
            // !! EDIT: INTERVAL_MS for auto-advance speed !!
            // ================================================================
            const HL_INTERVAL_MS = 4000;
            const HL_CARD_W_DESKTOP = 420;  // px, active card width on desktop
            const HL_CARD_H_DESKTOP = 240;  // px, active card height on desktop
            const HL_CARD_W_MOBILE  = 290;  // px, active card width on mobile (≤640px)
            const HL_CARD_H_MOBILE  = 190;  // px, active card height on mobile

            const hlStage = document.getElementById('hlStage');
            const hlScene = document.getElementById('hlScene');
            const hlCards = Array.from(document.querySelectorAll('.hl-card'));
            const hlDots  = Array.from(document.querySelectorAll('.hl-dot'));
            const HL_TOTAL = hlCards.length;

            // Continuous progress (fractional index, advances each frame)
            let hlProgress = 0;
            // Target integer index (jumps on click/swipe)
            let hlTargetIndex = 0;
            // Running rAF id
            let hlRafId = 0;
            // Auto-advance timer
            let hlAutoTimer = null;
            // Is auto-advance paused (hover/drag)
            let hlPaused = false;

            // Mouse state for parallax tilt on active card
            const hlMouse = { x: 0, y: 0, tx: 0, ty: 0, inside: false };

            // Touch drag state
            let hlTouchStartX = 0;
            let hlTouchStartY = 0;
            let hlIsDragging = false;
            let hlDragDelta = 0;

            // Card dimensions (updated on resize)
            let hlCardW = HL_CARD_W_DESKTOP;
            let hlCardH = HL_CARD_H_DESKTOP;

            // Update card + scene dimensions based on viewport
            function hlUpdateDimensions() {
                const isMobile = window.innerWidth <= 640;
                hlCardW = isMobile ? HL_CARD_W_MOBILE  : HL_CARD_W_DESKTOP;
                hlCardH = isMobile ? HL_CARD_H_MOBILE  : HL_CARD_H_DESKTOP;

                if (hlScene) {
                    hlScene.style.width  = hlCardW + 'px';
                    hlScene.style.height = hlCardH + 'px';
                    hlScene.style.transformStyle = 'preserve-3d';
                }
                hlCards.forEach(card => {
                    card.style.width  = hlCardW + 'px';
                    card.style.height = hlCardH + 'px';
                });
            }

            // Sync nav dots to the rounded active index
            function hlSyncDots(idx) {
                hlDots.forEach((dot, i) => {
                    dot.classList.toggle('hl-dot-active', i === idx);
                });
            }

            // Mark the visually centered card with .hl-is-active
            function hlMarkActive(idx) {
                hlCards.forEach((card, i) => {
                    card.classList.toggle('hl-is-active', i === idx);
                });
            }

            // rAF render loop
            function hlRender() {
                // Smoothly advance progress toward target
                const diff = hlTargetIndex - hlProgress;
                hlProgress += diff * 0.08;
                if (Math.abs(diff) < 0.001) hlProgress = hlTargetIndex;

                // Smooth mouse inertia
                hlMouse.x += (hlMouse.tx - hlMouse.x) * 0.08;
                hlMouse.y += (hlMouse.ty - hlMouse.y) * 0.08;

                const D = 1200; // perspective distance
                const stageW = hlStage ? hlStage.offsetWidth : window.innerWidth;
                const peekPx = 40; // how many px of side card peek at screen edge
                const gap    = 30; // gap between center and adjacent card edge (px)

                const roundedIdx = Math.round(hlProgress);
                hlMarkActive(((roundedIdx % HL_TOTAL) + HL_TOTAL) % HL_TOTAL);
                hlSyncDots(((roundedIdx % HL_TOTAL) + HL_TOTAL) % HL_TOTAL);

                hlCards.forEach((card, i) => {
                    // Solve circular offset in [-TOTAL/2, TOTAL/2]
                    let offset = i - hlProgress;
                    const half = HL_TOTAL / 2;
                    while (offset >  half) offset -= HL_TOTAL;
                    while (offset < -half) offset += HL_TOTAL;

                    const absOff = Math.abs(offset);
                    const sign   = offset < 0 ? -1 : (offset > 0 ? 1 : 0);

                    // Hide cards beyond 2.5 offsets
                    if (absOff > 2.5) {
                        card.style.visibility = 'hidden';
                        return;
                    }
                    card.style.visibility = 'visible';

                    let x = 0, z = 0, rotY = 0, rotX = 0, opac = 1;

                    if (absOff <= 1) {
                        // Center ↔ adjacent: smoothstep
                        const t = absOff;
                        const e = t * t * (3 - 2 * t);
                        // x: from 0 to half-width + gap (so card edges just touch)
                        const xTarget = hlCardW / 2 + hlCardW / 2 + gap;
                        x    =  sign * e * xTarget;
                        z    =  200 * (1 - e) + 60 * e;       // 200 → 60
                        rotY =  sign * e * 18;                 // 0 → ±18 deg
                        opac =  1 * (1 - e) + 0.40 * e;       // 1 → 0.40
                    } else if (absOff <= 2) {
                        // Adjacent ↔ edge peek: smoothstep
                        const t = absOff - 1;
                        const e = t * t * (3 - 2 * t);

                        const xStart = hlCardW / 2 + hlCardW / 2 + gap;
                        // x-end: right at stage edge minus peekPx so we see a sliver
                        const sEnd = D / (D - (-80));
                        const xEnd = (stageW / 2 - peekPx) / sEnd;

                        x    =  sign * (xStart + e * (xEnd - xStart));
                        z    =  60  * (1 - e) + (-80) * e;    // 60 → -80
                        rotY =  sign * (18 + e * (35 - 18));   // 18 → 35 deg
                        opac =  0.40 * (1 - e) + 0.10 * e;    // 0.40 → 0.10
                    } else {
                        // Beyond edge: smoothly vanish off-screen
                        const t = Math.min(absOff - 2, 1);
                        const e = t * t * (3 - 2 * t);

                        const sEnd2 = D / (D - (-80));
                        const xEdge = (stageW / 2 - peekPx) / sEnd2;
                        const xOff  = stageW / 2 + hlCardW;

                        x    =  sign * (xEdge + e * (xOff - xEdge));
                        z    =  -80  + e * (-200 - (-80));     // -80 → -200
                        rotY =  sign * 40;
                        opac =  0.10 * (1 - e);
                    }

                    // Mouse-driven tilt only on the active (center) card
                    const centerFactor = Math.max(0, 1 - absOff);
                    rotX = -hlMouse.y * 10 * centerFactor;
                    rotY += hlMouse.x * 8 * centerFactor;

                    // Depth sorting
                    card.style.zIndex = Math.round(z + 300).toString();
                    card.style.opacity = opac.toFixed(3);
                    card.style.transform = [
                        `translateX(${x.toFixed(2)}px)`,
                        `translateZ(${z.toFixed(2)}px)`,
                        `rotateY(${rotY.toFixed(2)}deg)`,
                        `rotateX(${rotX.toFixed(2)}deg)`
                    ].join(' ');
                });

                hlRafId = requestAnimationFrame(hlRender);
            }

            // Navigate to a specific integer index (wraps)
            function hlGoTo(idx) {
                // Choose the shortest circular path
                let delta = idx - hlTargetIndex;
                // Normalize delta into [-TOTAL/2, TOTAL/2]
                while (delta >  HL_TOTAL / 2) delta -= HL_TOTAL;
                while (delta < -HL_TOTAL / 2) delta += HL_TOTAL;
                hlTargetIndex += delta;
                hlSyncDots(((idx % HL_TOTAL) + HL_TOTAL) % HL_TOTAL);
            }

            // Advance by +1
            function hlNext() {
                hlGoTo(hlTargetIndex + 1);
            }

            // Start auto-advance
            function hlAutoStart() {
                if (hlAutoTimer) clearInterval(hlAutoTimer);
                hlAutoTimer = setInterval(() => {
                    if (!hlPaused) hlNext();
                }, HL_INTERVAL_MS);
            }

            // Stop auto-advance
            function hlAutoStop() {
                clearInterval(hlAutoTimer);
                hlAutoTimer = null;
            }

            // Restart auto-advance (reset timer after manual navigation)
            function hlAutoRestart() {
                hlAutoStop();
                hlAutoStart();
            }

            // === MOUSE (parallax tilt) ===
            if (hlStage) {
                hlStage.addEventListener('mousemove', e => {
                    const r = hlStage.getBoundingClientRect();
                    hlMouse.tx = ((e.clientX - r.left) / r.width  - 0.5) * 2;  // -1 to 1
                    hlMouse.ty = ((e.clientY - r.top)  / r.height - 0.5) * 2;
                    hlMouse.inside = true;
                });
                hlStage.addEventListener('mouseleave', () => {
                    hlMouse.tx = 0;
                    hlMouse.ty = 0;
                    hlMouse.inside = false;
                    hlPaused = false;
                });
                hlStage.addEventListener('mouseenter', () => {
                    hlPaused = true; // pause auto-advance while hovering
                });
            }

            // === CLICK on side cards ===
            hlCards.forEach((card, i) => {
                card.addEventListener('click', () => {
                    const currentActive = ((Math.round(hlTargetIndex) % HL_TOTAL) + HL_TOTAL) % HL_TOTAL;
                    if (i !== currentActive) {
                        // Compute direction-aware target
                        let delta = i - currentActive;
                        while (delta >  HL_TOTAL / 2) delta -= HL_TOTAL;
                        while (delta < -HL_TOTAL / 2) delta += HL_TOTAL;
                        hlTargetIndex += delta;
                        hlAutoRestart();
                    }
                });
            });

            // === DOT navigation ===
            hlDots.forEach((dot, i) => {
                dot.addEventListener('click', () => {
                    hlGoTo(i);
                    hlAutoRestart();
                });
            });

            // === TOUCH swipe ===
            if (hlStage) {
                hlStage.addEventListener('touchstart', e => {
                    hlTouchStartX = e.touches[0].clientX;
                    hlTouchStartY = e.touches[0].clientY;
                    hlIsDragging  = false;
                    hlDragDelta   = 0;
                    hlPaused      = true;
                }, { passive: true });

                hlStage.addEventListener('touchmove', e => {
                    const dx = e.touches[0].clientX - hlTouchStartX;
                    const dy = e.touches[0].clientY - hlTouchStartY;
                    if (!hlIsDragging && Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 6) {
                        hlIsDragging = true;
                        hlStage.classList.add('is-dragging');
                    }
                    if (hlIsDragging) {
                        hlDragDelta = dx;
                        // Live-drag: shift progress by fraction of card width
                        hlTargetIndex = Math.round(hlTargetIndex) - (dx / hlCardW);
                    }
                }, { passive: true });

                hlStage.addEventListener('touchend', () => {
                    if (hlIsDragging) {
                        // Snap to nearest integer if dragged far enough; else return to original
                        const snapped = Math.round(hlTargetIndex);
                        hlTargetIndex = snapped;
                    }
                    hlIsDragging = false;
                    hlDragDelta  = 0;
                    hlPaused     = false;
                    hlStage.classList.remove('is-dragging');
                    hlAutoRestart();
                }, { passive: true });
            }

            // === RESIZE ===
            window.addEventListener('resize', hlUpdateDimensions);

            // Init
            hlUpdateDimensions();
            hlRender();         // start rAF loop
            hlAutoStart();      // start auto-advance


            // ================================================================
            // PROJECTS HORIZONTAL CAROUSEL
            // Syncs slider thumb and arrow visibility to scroll position.
            // Supports: arrow click, slider drag, mouse drag-scroll.
            // !! EDIT: Change SCROLL_STEP for how far each arrow click moves !!
            // ================================================================
            const SCROLL_STEP = 340; // px scrolled per arrow click

            const projGrid = document.getElementById('projGrid');
            const projLeft = document.getElementById('projLeft');
            const projRight = document.getElementById('projRight');
            const projTrack = document.getElementById('projSliderTrack');
            const projThumb = document.getElementById('projSliderThumb');

            // -- Slider thumb sizing and positioning --
            function projUpdateSlider() {
                if (!projGrid || !projThumb) return;
                const { scrollLeft, scrollWidth, clientWidth } = projGrid;
                const ratio = clientWidth / scrollWidth;
                const thumbW = Math.max(ratio * 100, 8);         // percent width, min 8%
                const thumbPos = (scrollLeft / (scrollWidth - clientWidth)) * (100 - thumbW);
                projThumb.style.width = thumbW + '%';
                projThumb.style.left = (isNaN(thumbPos) ? 0 : thumbPos) + '%';
            }

            // -- Arrow visibility based on scroll position --
            function projUpdateArrows() {
                if (!projGrid) return;
                const { scrollLeft, scrollWidth, clientWidth } = projGrid;
                const atLeft = scrollLeft < 10;
                const atRight = scrollLeft > scrollWidth - clientWidth - 10;
                projLeft?.classList.toggle('visible', !atLeft);
                projRight?.classList.toggle('visible', !atRight);
            }

            // -- Combined update --
            function projUpdate() {
                projUpdateSlider();
                projUpdateArrows();
            }

            // Arrow click handlers
            projRight?.addEventListener('click', () => {
                projGrid.scrollBy({ left: SCROLL_STEP, behavior: 'smooth' });
            });
            projLeft?.addEventListener('click', () => {
                projGrid.scrollBy({ left: -SCROLL_STEP, behavior: 'smooth' });
            });

            // Sync on scroll
            projGrid?.addEventListener('scroll', projUpdate, { passive: true });

            // -- Slider drag --
            let sliderDragging = false;
            let sliderStartX = 0;
            let sliderScrollAt = 0;

            projThumb?.addEventListener('mousedown', e => {
                sliderDragging = true;
                sliderStartX = e.clientX;
                sliderScrollAt = projGrid.scrollLeft;
                projThumb.classList.add('dragging');
                e.preventDefault();
            });

            document.addEventListener('mousemove', e => {
                if (!sliderDragging) return;
                const trackW = projTrack.clientWidth;
                const thumbW = projThumb.offsetWidth;
                const available = trackW - thumbW;
                const dx = e.clientX - sliderStartX;
                const ratio = dx / available;
                const maxScroll = projGrid.scrollWidth - projGrid.clientWidth;
                projGrid.scrollLeft = Math.max(0, Math.min(maxScroll, sliderScrollAt + ratio * maxScroll));
            });

            document.addEventListener('mouseup', () => {
                if (!sliderDragging) return;
                sliderDragging = false;
                projThumb?.classList.remove('dragging');
            });

            // Click on track to jump
            projTrack?.addEventListener('click', e => {
                if (e.target === projThumb) return; // ignore thumb clicks
                const rect = projTrack.getBoundingClientRect();
                const clickPos = (e.clientX - rect.left) / rect.width;
                const maxScroll = projGrid.scrollWidth - projGrid.clientWidth;
                projGrid.scrollTo({ left: clickPos * maxScroll, behavior: 'smooth' });
            });

            // -- Mouse drag-to-scroll on card row --
            let isDragging = false;
            let dragStartX = 0;
            let scrollAtDrag = 0;

            projGrid?.addEventListener('mousedown', e => {
                isDragging = true;
                dragStartX = e.clientX;
                scrollAtDrag = projGrid.scrollLeft;
                projGrid.classList.add('dragging');
            });

            document.addEventListener('mousemove', e => {
                if (!isDragging) return;
                projGrid.scrollLeft = scrollAtDrag - (e.clientX - dragStartX);
            });

            document.addEventListener('mouseup', () => {
                isDragging = false;
                projGrid?.classList.remove('dragging');
            });

            // Initial render
            projUpdate();
            window.addEventListener('resize', projUpdate);


            // ================================================================
            // COURSES HORIZONTAL CAROUSEL
            // Syncs slider thumb and arrow visibility to scroll position.
            // Supports: arrow click, slider drag, mouse drag-scroll.
            // ================================================================
            const COURSE_SCROLL_STEP = 340; // px scrolled per arrow click

            const courseGrid = document.getElementById('courseGrid');
            const courseLeft = document.getElementById('courseLeft');
            const courseRight = document.getElementById('courseRight');
            const courseTrack = document.getElementById('courseSliderTrack');
            const courseThumb = document.getElementById('courseSliderThumb');

            // -- Slider thumb sizing and positioning --
            function courseUpdateSlider() {
                if (!courseGrid || !courseThumb) return;
                const { scrollLeft, scrollWidth, clientWidth } = courseGrid;
                const ratio = clientWidth / scrollWidth;
                const thumbW = Math.max(ratio * 100, 8);         // percent width, min 8%
                const thumbPos = (scrollLeft / (scrollWidth - clientWidth)) * (100 - thumbW);
                courseThumb.style.width = thumbW + '%';
                courseThumb.style.left = (isNaN(thumbPos) ? 0 : thumbPos) + '%';
            }

            // -- Arrow visibility based on scroll position --
            function courseUpdateArrows() {
                if (!courseGrid) return;
                const { scrollLeft, scrollWidth, clientWidth } = courseGrid;
                const atLeft = scrollLeft < 10;
                const atRight = scrollLeft > scrollWidth - clientWidth - 10;
                courseLeft?.classList.toggle('visible', !atLeft);
                courseRight?.classList.toggle('visible', !atRight);
            }

            // -- Combined update --
            function courseUpdate() {
                courseUpdateSlider();
                courseUpdateArrows();
            }

            // Arrow click handlers
            courseRight?.addEventListener('click', () => {
                courseGrid.scrollBy({ left: COURSE_SCROLL_STEP, behavior: 'smooth' });
            });
            courseLeft?.addEventListener('click', () => {
                courseGrid.scrollBy({ left: -COURSE_SCROLL_STEP, behavior: 'smooth' });
            });

            // Sync on scroll
            courseGrid?.addEventListener('scroll', courseUpdate, { passive: true });

            // -- Slider drag --
            let courseSliderDragging = false;
            let courseSliderStartX = 0;
            let courseSliderScrollAt = 0;

            courseThumb?.addEventListener('mousedown', e => {
                courseSliderDragging = true;
                courseSliderStartX = e.clientX;
                courseSliderScrollAt = courseGrid.scrollLeft;
                courseThumb.classList.add('dragging');
                e.preventDefault();
            });

            document.addEventListener('mousemove', e => {
                if (!courseSliderDragging) return;
                const trackW = courseTrack.clientWidth;
                const thumbW = courseThumb.offsetWidth;
                const available = trackW - thumbW;
                const dx = e.clientX - courseSliderStartX;
                const ratio = dx / available;
                const maxScroll = courseGrid.scrollWidth - courseGrid.clientWidth;
                courseGrid.scrollLeft = Math.max(0, Math.min(maxScroll, courseSliderScrollAt + ratio * maxScroll));
            });

            document.addEventListener('mouseup', () => {
                if (!courseSliderDragging) return;
                courseSliderDragging = false;
                courseThumb?.classList.remove('dragging');
            });

            // Click on track to jump
            courseTrack?.addEventListener('click', e => {
                if (e.target === courseThumb) return; // ignore thumb clicks
                const rect = courseTrack.getBoundingClientRect();
                const clickPos = (e.clientX - rect.left) / rect.width;
                const maxScroll = courseGrid.scrollWidth - courseGrid.clientWidth;
                courseGrid.scrollTo({ left: clickPos * maxScroll, behavior: 'smooth' });
            });

            // -- Mouse drag-to-scroll on card row --
            let courseIsDragging = false;
            let courseDragStartX = 0;
            let courseScrollAtDrag = 0;

            courseGrid?.addEventListener('mousedown', e => {
                courseIsDragging = true;
                courseDragStartX = e.clientX;
                courseScrollAtDrag = courseGrid.scrollLeft;
                courseGrid.classList.add('dragging');
            });

            document.addEventListener('mousemove', e => {
                if (!courseIsDragging) return;
                courseGrid.scrollLeft = courseScrollAtDrag - (e.clientX - courseDragStartX);
            });

            document.addEventListener('mouseup', () => {
                courseIsDragging = false;
                courseGrid?.classList.remove('dragging');
            });

            // Initial render
            courseUpdate();
            window.addEventListener('resize', courseUpdate);

        });
        /* ============================================================
   ABOUT SECTION TOGGLE
   Switches between 'The Builder' and 'The Human' bios
============================================================ */

        function toggleAbout(section) {
            const tabsWrapper = document.getElementById('aboutTabs');
            const indicator = document.getElementById('tabIndicator');
            const builderBtn = document.getElementById('tabBuilder');
            const humanBtn = document.getElementById('tabHuman');
            const builderContent = document.getElementById('bio-builder');
            const humanContent = document.getElementById('bio-human');

            if (!builderContent || !humanContent || !builderBtn || !humanBtn) return;

            // Remove active from all, then add to the selected
            [builderBtn, humanBtn].forEach(btn => {
                btn.classList.remove('active');
                btn.setAttribute('aria-pressed', 'false');
            });

            const activeBtn = section === 'builder' ? builderBtn : humanBtn;
            activeBtn.classList.add('active');
            activeBtn.setAttribute('aria-pressed', 'true');

            // Slide indicator using layout-relative offsetLeft/offsetWidth so scroll
            // position never skews the calculation.
            if (indicator && tabsWrapper) {
                const PADDING = 4; // tabs container padding
                const maxLeft = tabsWrapper.clientWidth - PADDING - activeBtn.offsetWidth;
                const targetLeft = Math.max(PADDING, Math.min(maxLeft, activeBtn.offsetLeft));
                indicator.style.left = targetLeft + 'px';
                indicator.style.width = activeBtn.offsetWidth + 'px';
            }

            // Toggle purple tint on the indicator when "human" is active
            tabsWrapper?.classList.toggle('human-active', section === 'human');

            // Swap content
            if (section === 'builder') {
                humanContent.classList.replace('active-bio', 'hidden-bio');
                builderContent.classList.replace('hidden-bio', 'active-bio');
            } else {
                builderContent.classList.replace('active-bio', 'hidden-bio');
                humanContent.classList.replace('hidden-bio', 'active-bio');
            }
        }

        // Initialise indicator position on load (no transition on first paint)
        (function initTabIndicator() {
            const tabs = document.getElementById('aboutTabs');
            const ind = document.getElementById('tabIndicator');
            const active = document.querySelector('.tab-btn.active');
            if (!tabs || !ind || !active) return;

            requestAnimationFrame(() => {
                // Suppress transition on first placement so it snaps instantly
                ind.style.transition = 'none';
                const PADDING = 4;
                const maxLeft = tabs.clientWidth - PADDING - active.offsetWidth;
                ind.style.left = Math.max(PADDING, Math.min(maxLeft, active.offsetLeft)) + 'px';
                ind.style.width = active.offsetWidth + 'px';
                // Re-enable transition after the first frame is committed
                requestAnimationFrame(() => { ind.style.transition = ''; });
            });
        })();// end DOMContentLoaded
    </script>

</body>

</html>